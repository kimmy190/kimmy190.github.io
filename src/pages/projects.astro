---
import Layout from "../layouts/Layout.astro";
import MobileNav from "../components/MobileNav.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import { projects } from "../data/site";
---

<Layout
  title="Projects — Amy Kim"
  description="Detailed project write-ups from Amy Kim — full-stack apps, data visualization, and AI-driven automation."
>
  <MobileNav />
  <div class="md:mx-auto md:flex md:max-w-6xl md:items-start md:gap-16 md:px-8">
    <Sidebar />
    <div class="min-w-0 flex-1">
  <main class="px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <p class="reveal font-mono text-xs font-semibold tracking-widest text-accent-deep uppercase">$ ls projects/</p>
      <h1 class="reveal mt-3 text-3xl font-semibold text-ink md:text-4xl">Projects</h1>
      <p class="reveal mt-4 max-w-xl leading-relaxed text-ink-muted">
        Things I've built outside of work — some with teams, some solo.
      </p>

      <div class="mt-14 space-y-14">
        {
          projects.map((project, i) => (
            <article class="reveal relative pl-8">
              <div class="absolute top-0 left-0 flex h-full w-8 flex-col items-center">
                <span class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-accent" />
                {i !== projects.length - 1 && <span class="mt-1 w-px flex-1 bg-line" />}
              </div>

              <p class="font-mono text-xs text-ink-muted">
                {project.start} – {project.end}
              </p>
              <h2 class="mt-1 text-xl font-semibold text-ink">{project.name}</h2>

              <p class="mt-4 leading-relaxed text-ink-muted">{project.narrative}</p>

              <ul class="mt-4 space-y-2">
                {project.bullets.map((bullet) => (
                  <li class="flex gap-2 text-sm leading-relaxed text-ink-muted">
                    <span class="mt-1 text-accent">▸</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-4 flex flex-wrap gap-2">
                {project.stack.map((tech) => (
                  <span class="rounded-full bg-accent-soft px-2.5 py-0.5 text-xs text-accent-deep">{tech}</span>
                ))}
              </div>

              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent-deep hover:underline"
                >
                  View repository ↗
                </a>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </main>
  <Footer />
    </div>
  </div>
</Layout>
