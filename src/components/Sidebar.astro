---
const { pathname } = Astro.url;

const navItems = [
  { href: "/#about", label: "About" },
  { href: "/work", label: "Work", match: "/work" },
  { href: "/projects", label: "Projects", match: "/projects" },
];
const isActive = (match?: string) => Boolean(match) && pathname === match;
---

<aside class="hidden md:sticky md:top-10 md:flex md:w-48 md:shrink-0 md:flex-col md:py-10">
  <a href="/" class="inline-flex flex-col items-start gap-3">
    <span class="flex h-7 w-7 items-center justify-center rounded-md bg-accent font-mono text-xs font-semibold text-cream">
      A
    </span>
    <span class="font-mono text-sm font-semibold tracking-tight text-ink">amy.dev</span>
  </a>

  <nav class="mt-10 flex flex-col gap-3 text-sm">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class={`transition-colors hover:text-accent-deep ${isActive(item.match) ? "font-medium text-ink" : "text-ink-muted"}`}
        >
          {item.label}
        </a>
      ))
    }
    <a href="/#contact" class="mt-6 text-ink-muted transition-colors hover:text-accent-deep">
      Contact
    </a>
  </nav>
</aside>
