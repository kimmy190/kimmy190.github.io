---
import { profile, education } from "../data/site";
---

<section id="about" class="px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <p class="reveal font-mono text-xs font-semibold tracking-widest text-accent-deep uppercase">$ cat about.md</p>
    <h2 class="reveal mt-3 text-2xl font-semibold text-ink md:text-3xl">About</h2>

    <p class="reveal mt-6 leading-relaxed text-ink-muted">
      {profile.summary[2]}
    </p>

    <div class="reveal mt-10 rounded-lg border border-line bg-cream-soft/60 p-6">
      <p class="text-xs font-semibold tracking-widest text-ink-muted uppercase">Education</p>
      <p class="mt-2 font-medium text-ink">{education.degree}</p>
      <p class="text-sm text-ink-muted">{education.school}</p>
      <ul class="mt-3 space-y-1">
        {
          education.honors.map((honor) => (
            <li class="text-sm text-accent-deep">★ {honor}</li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
