---
import { contact } from "../data/site";
---

<section id="contact" class="px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <p class="reveal font-mono text-xs font-semibold tracking-widest text-accent-deep uppercase">$ contact --open</p>
    <h2 class="reveal mt-3 text-2xl font-semibold text-ink md:text-3xl">Let's work together</h2>
    <p class="reveal mt-4 max-w-xl leading-relaxed text-ink-muted">
      Open to freelance, full-time, and collaborative opportunities. The fastest way to reach me is email.
    </p>

    <div class="reveal mt-8 flex flex-wrap gap-3">
      <a
        href={`mailto:${contact.email}`}
        class="rounded-md bg-accent px-5 py-2.5 text-sm font-medium text-cream transition-colors hover:bg-accent-deep"
      >
        {contact.email}
      </a>
      <a
        href={contact.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md border border-line px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:border-accent hover:text-accent-deep"
      >
        LinkedIn
      </a>
      <a
        href={contact.github}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md border border-line px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:border-accent hover:text-accent-deep"
      >
        GitHub
      </a>
    </div>
  </div>
</section>
