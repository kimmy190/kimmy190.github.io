---
import { projects } from "../data/site";
---

<section id="projects" class="px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <p class="reveal font-mono text-xs font-semibold tracking-widest text-accent-deep uppercase">$ ls projects/</p>
    <h2 class="reveal mt-3 text-2xl font-semibold text-ink md:text-3xl">Projects</h2>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {
        projects.map((project) => (
          <article class="reveal group relative flex flex-col rounded-lg border border-line bg-cream-soft/60 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:shadow-lg hover:shadow-accent-soft">
            <p class="font-mono text-xs text-ink-muted">
              {project.start} – {project.end}
            </p>
            <h3 class="mt-1 text-lg font-semibold text-ink group-hover:text-accent-deep">
              {project.link ? (
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="after:absolute after:inset-0">
                  {project.name}
                </a>
              ) : (
                project.name
              )}
            </h3>
            <ul class="mt-3 space-y-2">
              {project.bullets.map((bullet) => (
                <li class="flex gap-2 text-sm leading-relaxed text-ink-muted">
                  <span class="mt-1 text-accent">▸</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
            <div class="mt-4 flex flex-wrap gap-2">
              {project.stack.map((tech) => (
                <span class="rounded-full bg-accent-soft px-2.5 py-0.5 text-xs text-accent-deep">{tech}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
