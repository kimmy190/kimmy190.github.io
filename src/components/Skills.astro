---
import { skills } from "../data/site";
---

<section id="skills" class="px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <p class="reveal font-mono text-xs font-semibold tracking-widest text-accent-deep uppercase">$ ls skills/</p>
    <h2 class="reveal mt-3 text-2xl font-semibold text-ink md:text-3xl">Skills</h2>

    <div class="reveal mt-8">
      <p class="text-xs font-semibold tracking-widest text-ink-muted uppercase">Languages</p>
      <div class="mt-3 flex flex-wrap gap-2">
        {
          skills.languages.map((skill) => (
            <span class="rounded-full border border-line bg-cream-soft px-3 py-1 text-xs text-ink">{skill}</span>
          ))
        }
      </div>
    </div>

    <div class="reveal mt-6">
      <p class="text-xs font-semibold tracking-widest text-ink-muted uppercase">Tools &amp; Frameworks</p>
      <div class="mt-3 flex flex-wrap gap-2">
        {
          skills.tools.map((skill) => (
            <span class="rounded-full border border-line bg-cream-soft px-3 py-1 text-xs text-ink">{skill}</span>
          ))
        }
      </div>
    </div>
  </div>
</section>
