---
import { experience } from "../data/site";
---

<section id="experience" class="px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <p class="reveal font-mono text-xs font-semibold tracking-widest text-accent-deep uppercase">$ ls experience/</p>
    <h2 class="reveal mt-3 text-2xl font-semibold text-ink md:text-3xl">Experience</h2>

    <div class="mt-10 space-y-10">
      {
        experience.map((job, i) => (
          <div class="reveal relative pl-8">
            <div class="absolute top-0 left-0 flex h-full w-8 flex-col items-center">
              <span class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-accent" />
              {i !== experience.length - 1 && <span class="mt-1 w-px flex-1 bg-line" />}
            </div>
            <p class="font-mono text-xs text-ink-muted">
              {job.start} – {job.end}
            </p>
            <h3 class="mt-1 text-lg font-semibold text-ink">{job.role}</h3>
            <p class="text-sm text-ink-muted">
              {job.org}
              {job.location ? ` · ${job.location}` : ""}
            </p>
            <ul class="mt-3 space-y-2">
              {job.bullets.map((bullet) => (
                <li class="flex gap-2 text-sm leading-relaxed text-ink-muted">
                  <span class="mt-1 text-accent">▸</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
            <div class="mt-3 flex flex-wrap gap-2">
              {job.stack.map((tech) => (
                <span class="rounded-full bg-accent-soft px-2.5 py-0.5 text-xs text-accent-deep">{tech}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
