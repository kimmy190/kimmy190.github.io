---
import { profile } from "../data/site";
---

<section id="top" class="relative overflow-hidden px-6 pt-20 pb-24 md:pt-28 md:pb-32">
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-35"
    style="background-image: radial-gradient(var(--color-line) 1px, transparent 1px); background-size: 22px 22px;"
  >
  </div>

  <div class="mx-auto max-w-3xl">
    <p class="reveal font-mono text-sm text-accent-deep">
      <span class="text-ink-muted">$</span> whoami<span class="cursor-blink text-accent">_</span>
    </p>
    <h1 class="reveal mt-4 text-4xl font-semibold tracking-tight text-ink md:text-5xl">
      Hi, I'm {profile.name}.
    </h1>
    <p class="reveal mt-4 text-lg text-ink-muted md:text-xl">
      {profile.role} · {profile.location}
    </p>
    <p class="reveal mt-6 max-w-xl text-base leading-relaxed text-ink-muted">
      {profile.summary[0]}
    </p>

    <div class="reveal mt-8 flex flex-wrap gap-3">
      <a
        href="#projects"
        class="rounded-md bg-accent px-5 py-2.5 text-sm font-medium text-cream transition-colors hover:bg-accent-deep"
      >
        View projects
      </a>
      <a
        href="#contact"
        class="rounded-md border border-line px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:border-accent hover:text-accent-deep"
      >
        Get in touch
      </a>
    </div>
  </div>
</section>
